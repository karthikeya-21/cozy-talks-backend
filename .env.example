PORT=3001
FRONTEND_URL=http://localhost:3000
# Neon pooled connection for the running app
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-POOLER-HOST.neon.tech/neondb?sslmode=require&channel_binding=require"
# Neon direct connection for Prisma db push / migrations
DIRECT_URL="postgresql://USER:PASSWORD@YOUR-DIRECT-HOST.neon.tech/neondb?sslmode=require&channel_binding=require"
JWT_SECRET=super-secret-jwt-key
JWT_EXPIRES_IN=7d
